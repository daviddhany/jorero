<%- include('partials/header') %>
<% const imgs = (product.images && product.images.length) ? product.images : ['/public/images/logo.png']; %>
<% const autoOffer = product.offerBuyQty && product.offerDiscountPercent ? ('اشتري ' + product.offerBuyQty + ' وخد خصم ' + product.offerDiscountPercent + '%') : ''; %>
<% const sizeOptions = [...new Set((product.sizes || []).filter(Boolean).map(v => String(v).trim()).filter(Boolean))]; %>
<% const colorOptions = [...new Set([...(product.colors || []), ...((product.colorImages || []).map(item => item.color))].filter(Boolean).map(v => String(v).trim()).filter(Boolean))]; %>
<section class="product-detail showroom-detail">
  <div class="product-gallery" data-images='<%- JSON.stringify(imgs) %>'>
    <img id="mainImg" class="main-img" src="<%= imgs[0] %>" alt="<%= product.name %>" onerror="this.onerror=null;this.src='/public/images/logo.png'">
    <div class="image-stage">
      <button type="button" class="gallery-arrow gallery-prev" onclick="moveProductPhoto(-1)">‹</button>
      <button type="button" class="gallery-arrow gallery-next" onclick="moveProductPhoto(1)">›</button>
    </div>
    <div class="thumbs" id="productThumbs">
      <% imgs.forEach((img, index) => { %>
        <img class="<%= index === 0 ? 'active' : '' %>" data-img="<%= img %>" onclick="setProductPhoto(<%= index %>)" src="<%= img %>" alt="<%= product.name %>" onerror="this.onerror=null;this.src='/public/images/logo.png'">
      <% }) %>
    </div>
    <% if (product.colorImages && product.colorImages.length) { %>
      <div class="color-gallery">
        <h3>الألوان المتاحة</h3>
        <div class="color-photo-options">
          <% product.colorImages.forEach(item => { %>
            <button type="button" class="color-photo-btn" data-image="<%= item.image %>" data-color="<%= item.color %>">
              <img src="<%= item.image %>" alt="<%= item.color %>" onerror="this.onerror=null;this.src='/public/images/logo.png'">
              <span><%= item.color %></span>
            </button>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="detail-panel">
    <span class="tag"><%= product.category %></span>
    <% if(product.offer){ %><span class="tag offer-tag"><%= product.offerText || autoOffer || 'عرض خاص' %></span><% } %>
    <h1><%= product.name %></h1>
    <h2><%= formatPrice(product.price) %> <% if(product.oldPrice){ %><del><%= formatPrice(product.oldPrice) %></del><% } %></h2>
    <% if(product.offerText || autoOffer){ %><p class="offer-detail">🔥 <%= product.offerText || autoOffer %></p><% } %>
    <p><%= product.description || '' %></p>

    <form class="buy-box" method="post" action="/cart/add/<%= product._id %>">
      <input type="hidden" id="selectedImage" name="image" value="<%= imgs[0] %>">

      <label>المقاس
        <select id="sizeSelect" name="size" <%= sizeOptions.length ? 'required' : '' %>>
          <option value=""><%= sizeOptions.length ? 'اختار المقاس' : 'لا يوجد مقاسات محددة' %></option>
          <% sizeOptions.forEach(s=>{ %><option value="<%= s %>"><%= s %></option><% }) %>
        </select>
      </label>

      <label>اللون
        <select id="colorSelect" name="color" <%= colorOptions.length ? 'required' : '' %>>
          <option value=""><%= colorOptions.length ? 'اختار اللون' : 'لا يوجد ألوان محددة' %></option>
          <% colorOptions.forEach(c=>{ %><option value="<%= c %>"><%= c %></option><% }) %>
        </select>
      </label>

      <label>الكمية<input type="number" min="1" name="quantity" value="1" required></label>
      <button type="submit" class="btn big">إضافة للسلة</button>
    </form>
    <div class="hero-actions"><a class="btn light" href="/products">كمل تسوق</a><a class="btn light" href="/cart">افتح السلة</a></div>
  </div>
</section>
<%- include('partials/footer') %>
