<%- include('partials/header') %>
<section class="success-box">
  <h1>تم إرسال طلبك بنجاح ✅</h1>
  <p>رقم الطلب: <b><%= order._id %></b></p>
  <div class="order-summary-list">
    <% order.items.forEach(item=>{ %>
      <div class="summary-item">
        <p><b><%= item.name %></b></p>
        <p>المقاس: <%= item.size || '-' %> | اللون: <%= item.color || '-' %></p>
        <p>الكمية: <%= item.quantity %> — <b><%= formatPrice(item.subtotal) %></b></p>
      </div>
    <% }) %>
  </div>
  <p>الإجمالي: <b><%= formatPrice(order.total) %></b></p>
  <p>هنراجع الطلب ونتواصل معاك على رقم التليفون.</p>
  <a class="btn big" href="/products">تسوق منتجات أخرى</a>
</section>
<%- include('partials/footer') %>
